{
  "contractVersion": "v1",
  "owner": "main-orchestrator",
  "store": {
    "kind": "central-state-store",
    "writeMode": "validated-patch"
  },
  "sharedValues": {
    "runId": {
      "type": "string",
      "owner": "main-orchestrator",
      "required": true,
      "mutable": false,
      "allowedWriters": [
        "main-orchestrator"
      ],
      "writeMode": "immutable",
      "conflictPolicy": "reject"
    },
    "hostTarget": {
      "type": "string",
      "owner": "main-orchestrator",
      "required": true,
      "mutable": true,
      "allowedWriters": [
        "main-orchestrator"
      ],
      "writeMode": "replace",
      "conflictPolicy": "reject",
      "allowedValues": [
        "codex",
        "claude",
        "local"
      ]
    },
    "inputRefs": {
      "type": "object",
      "owner": "main-orchestrator",
      "required": true,
      "mutable": true,
      "allowedWriters": [
        "main-orchestrator"
      ],
      "writeMode": "replace",
      "conflictPolicy": "reject"
    },
    "stageStatus": {
      "type": "object",
      "owner": "main-orchestrator",
      "required": true,
      "mutable": true,
      "allowedWriters": [
        "main-orchestrator"
      ],
      "writeMode": "replace",
      "conflictPolicy": "reject"
    },
    "artifactVersion": {
      "type": "string",
      "owner": "main-orchestrator",
      "required": true,
      "mutable": true,
      "allowedWriters": [
        "main-orchestrator"
      ],
      "writeMode": "replace",
      "conflictPolicy": "reject"
    },
    "workerOutputs": {
      "type": "object",
      "owner": "worker-orchestrators",
      "required": false,
      "mutable": true,
      "allowedWriters": [
        "prompt-orchestrator",
        "secure-orchestrator",
        "optimize-orchestrator"
      ],
      "writeMode": "namespaced-patch",
      "conflictPolicy": "namespace-owner"
    }
  },
  "patchRules": {
    "requireSnapshotVersion": true,
    "allowFullRewrite": false,
    "rejectUnknownKeys": true,
    "failOnMeaningConflict": true
  },
  "workerNamespaces": {
    "prompt-orchestrator": [
      "workerOutputs.prompt-orchestrator"
    ],
    "secure-orchestrator": [
      "workerOutputs.secure-orchestrator"
    ],
    "optimize-orchestrator": [
      "workerOutputs.optimize-orchestrator"
    ]
  }
}
